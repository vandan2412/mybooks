<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scrollBill"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp"
    tools:context=".PrintPreviewActivit">

    <LinearLayout
        android:id="@+id/billLayout"
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="#FFFFFF"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INVOICE"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F0F0F0"
            android:padding="4dp"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tvInvoiceNo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Invoice No: 12345"
                android:textStyle="bold"
                android:textSize="14sp"/>
            <TextView android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Date: 15/11/2025"
                android:textSize="13sp"/>
            <TextView android:id="@+id/tvParty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To: Party Name"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp"
            android:background="#CCCCCC">

            <TextView android:text="SNo"
                android:layout_width="30dp"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="12sp"/>
            <TextView android:text="Item"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="12sp"/>
            <TextView android:text="Qty"
                android:layout_width="50dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textStyle="bold"
                android:textSize="12sp"/>
            <TextView android:text="Rate"
                android:layout_width="65dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textStyle="bold"
                android:textSize="12sp"/>
            <TextView android:text="Total (₹)"
                android:layout_width="75dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textStyle="bold"
                android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="10dp"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000" android:layout_marginVertical="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingHorizontal="8dp">
            <TextView android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sub-Total: ₹ 100.00"
                android:textSize="13sp"/>
            <TextView android:id="@+id/tvDiscount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discount: - ₹ 10.00"
                android:textSize="13sp"/>
            <TextView android:id="@+id/tvTax"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tax: + ₹ 5.00"
                android:textSize="13sp"/>
            <TextView android:id="@+id/tvNetTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grand Total: ₹ 95.00"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#000000" android:layout_marginVertical="4dp"/>


        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="WhatsApp Number (default +91)"
            android:inputType="phone"
            android:layout_marginTop="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android.gravity="center"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnPrint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Print/PDF"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnWhatsApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send WhatsApp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
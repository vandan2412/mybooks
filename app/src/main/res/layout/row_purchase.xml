<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView android:id="@+id/tvSno" android:layout_width="40dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvDate" android:layout_width="90dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvInvoice" android:layout_width="90dp" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvParty" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvAmount" android:layout_width="90dp" android:layout_height="wrap_content" android:gravity="right"/>
</LinearLayout>
